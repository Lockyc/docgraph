#!/usr/bin/env bash
# Auto-deploy docaudit on this machine (its only host): reinstall the binary from
# the just-committed source so ~/go/bin/docaudit always matches HEAD. Without this
# the gate silently runs a stale build — an edited source with an un-reinstalled
# binary keeps gating pushes with old logic. Runs on commit and on merge/pull
# (post-merge execs this). Activate with: git config core.hooksPath .githooks
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
if go install . 2>/tmp/docaudit-install.err; then
  bin="$(go env GOBIN 2>/dev/null)"; [ -z "$bin" ] && bin="$(go env GOPATH 2>/dev/null)/bin"
  echo "docaudit: reinstalled $(git rev-parse --short HEAD) -> $bin/docaudit"
else
  echo "docaudit: go install failed — ~/go/bin/docaudit NOT updated (see /tmp/docaudit-install.err)" >&2
fi
